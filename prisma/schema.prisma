generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id    Int    @id @default(autoincrement())
  name  String @db.VarChar(100)
  email String @unique @db.VarChar(255)
  role  String @db.VarChar(10)
}

model Login {
  id        Int     @id @default(autoincrement())
  login String  @unique
  password  String
  permission   String 
  createdAt  DateTime @default(now())
}
